# backend/api/webhooks/.htaccess
# Security: IP Whitelisting for Webhook Platforms

<RequireAny>
  # Meta IP ranges
  Require ip 31.13.24.0/21
  Require ip 31.13.64.0/18
  Require ip 66.220.144.0/20
  Require ip 69.63.176.0/20
  Require ip 129.134.0.0/17
  Require ip 157.240.0.0/17
  Require ip 173.252.64.0/18
  Require ip 179.60.192.0/18
  Require ip 185.60.216.0/22
  Require ip 204.15.20.0/22

  # Google IP ranges
  Require ip 66.249.64.0/19
  Require ip 209.85.128.0/17
  Require ip 35.190.0.0/17
  Require ip 35.191.0.0/16
  Require ip 104.133.0.0/16
  Require ip 104.134.0.0/15
  Require ip 104.154.0.0/15
  Require ip 107.178.192.0/18
  Require ip 108.170.192.0/18
  Require ip 108.177.0.0/17

  # LinkedIn IP ranges
  Require ip 108.174.0.0/20
  Require ip 144.2.0.0/16
  Require ip 199.101.160.0/22
  Require ip 216.52.242.0/24

  # Localhost & Loopback
  Require ip 127.0.0.1
  Require ip ::1
</RequireAny>

# Prevent directory listing
Options -Indexes
